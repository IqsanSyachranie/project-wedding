generator client {
  provider = "prisma-client-js"
  output   = "../src/dbmodel/wed"
}

datasource db {
  provider = "mysql"
}

model AdminUser {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
